{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vibeshield.local/pitch-v2/demo-evidence-packet.schema.json",
  "title": "VibeShield Pitch V2 Demo Evidence Packet",
  "description": "SPEC_ONLY schema for a future filled evidence packet. It validates evidence required before LIVE or RECORDED REAL RUN claims; it does not represent current live evidence.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "route",
    "decision",
    "evidence_identifiers",
    "truth_badges",
    "timing",
    "capability_downgrades",
    "presenter_signoff"
  ],
  "properties": {
    "route": {
      "type": "string",
      "enum": ["LIVE", "RECORDED_REAL_RUN", "LOCAL_FALLBACK", "ROADMAP_NOT_CONFIGURED"]
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["owner", "time", "demo_surface", "source_label_shown_to_judge", "fallback_route"],
      "properties": {
        "owner": { "type": "string", "minLength": 1 },
        "time": { "type": "string", "minLength": 1 },
        "demo_surface": { "type": "string", "minLength": 1 },
        "source_label_shown_to_judge": {
          "type": "string",
          "enum": ["LIVE", "RECORDED_REAL_RUN", "LOCAL_FALLBACK", "NOT_CONFIGURED", "ROADMAP"]
        },
        "fallback_route": {
          "type": "string",
          "enum": ["RECORDED_REAL_RUN", "LOCAL_FALLBACK", "ROADMAP_NOT_CONFIGURED"]
        }
      }
    },
    "evidence_identifiers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "run_id", "before_artifact_path", "after_artifact_path", "verify_artifact_path"],
      "properties": {
        "project_id": { "type": "string" },
        "run_id": { "type": "string" },
        "test_id": { "type": "string" },
        "trace_id": { "type": "string" },
        "before_artifact_path": { "type": "string" },
        "after_artifact_path": { "type": "string" },
        "verify_artifact_path": { "type": "string" },
        "ci_artifact_or_workflow_path": { "type": "string" }
      }
    },
    "truth_badges": {
      "type": "array",
      "minItems": 9,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["segment", "planned_badge", "evidence_field", "downgrade_if_missing"],
        "properties": {
          "segment": { "type": "string", "minLength": 1 },
          "planned_badge": {
            "type": "string",
            "enum": ["LIVE", "RECORDED_REAL_RUN", "LOCAL_FALLBACK", "NOT_CONFIGURED", "ROADMAP"]
          },
          "evidence_field": { "type": "string", "minLength": 1 },
          "downgrade_if_missing": {
            "type": "string",
            "enum": ["RECORDED_REAL_RUN", "LOCAL_FALLBACK", "NOT_CONFIGURED", "ROADMAP"]
          }
        }
      }
    },
    "timing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["three_minute_timing_pass", "runs"],
      "properties": {
        "three_minute_timing_pass": { "type": "boolean", "const": false },
        "runs": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "run_number",
              "source_label",
              "start",
              "stop",
              "duration_seconds",
              "failure_visible_by_70s",
              "fix_starts_by_95s",
              "after_proof_by_150s",
              "pass",
              "evidence_path"
            ],
            "properties": {
              "run_number": { "type": "integer", "minimum": 1, "maximum": 3 },
              "source_label": {
                "type": "string",
                "enum": ["LIVE", "RECORDED_REAL_RUN", "LOCAL_FALLBACK"]
              },
              "start": { "type": "string" },
              "stop": { "type": "string" },
              "duration_seconds": { "type": "number", "minimum": 0 },
              "failure_visible_by_70s": { "type": "boolean" },
              "fix_starts_by_95s": { "type": "boolean" },
              "after_proof_by_150s": { "type": "boolean" },
              "pass": { "type": "boolean" },
              "evidence_path": { "type": "string" }
            }
          }
        }
      }
    },
    "capability_downgrades": {
      "type": "array",
      "minItems": 5,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["capability", "default_label", "upgrade_evidence_required", "current_position"],
        "properties": {
          "capability": { "type": "string", "minLength": 1 },
          "default_label": {
            "type": "string",
            "enum": ["ROADMAP", "NOT_CONFIGURED", "STATIC_REVIEW_INDICATOR"]
          },
          "upgrade_evidence_required": { "type": "string", "minLength": 1 },
          "current_position": { "type": "string", "minLength": 1 }
        }
      }
    },
    "presenter_signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route_chosen",
        "evidence_packet_complete",
        "three_rehearsals_measured",
        "any_live_badge_without_evidence",
        "any_do_not_claim_item_still_in_script",
        "final_safe_close_selected"
      ],
      "properties": {
        "route_chosen": { "type": "boolean" },
        "evidence_packet_complete": { "type": "boolean" },
        "three_rehearsals_measured": { "type": "boolean" },
        "any_live_badge_without_evidence": { "type": "boolean", "const": false },
        "any_do_not_claim_item_still_in_script": { "type": "boolean", "const": false },
        "final_safe_close_selected": { "type": "string", "minLength": 1 }
      }
    }
  }
}
