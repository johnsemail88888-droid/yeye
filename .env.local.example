# VibeShield optional real integrations — copy to .env.local and fill in.
# Without these, the full demo still runs offline with honest "local/compatible" labels.
# Never commit real keys.

# Real Claude agent (replaces the deterministic stand-in; the model can be injected for real).
ANTHROPIC_API_KEY=

# Real Arize Phoenix UI (else local OpenInference experiment is the source of truth).
PHOENIX_COLLECTOR_ENDPOINT=

# Real ArmorIQ SDK (else the local ArmorIQ-compatible guard is used).
ARMORIQ_API_KEY=

# Optional founder/CTO voice briefing.
DEEPGRAM_API_KEY=
